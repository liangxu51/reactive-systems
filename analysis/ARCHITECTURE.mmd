graph TD
  subgraph Frontend_Tier["Frontend Tier"]
    FE[Frontend React/Vite UI]
  end

  subgraph OrderService_Tier["order-service (reactive, :8080)"]
    OC[OrderController]
    OS[OrderService]
    OCons[OrderConsumer]
    OProd[OrderProducer]
    ORepo[(OrderRepository / order collection)]
  end

  subgraph OrderServiceVT_Tier["order-service-vt (virtual threads, :8083, mutually exclusive)"]
    VOC[VT OrderController]
    VOS[VT OrderService]
    VOCons[VT OrderConsumer]
    VOProd[VT OrderProducer]
    VORepo[(VT OrderRepository / order collection)]
  end

  subgraph InventoryService_Tier["inventory-service (:8081)"]
    PC[ProductController]
    PS[ProductService]
    ICons[Inventory OrderConsumer]
    IProd[Inventory OrderProducer]
    PRepo[(ProductRepository / product collection)]
  end

  subgraph ShippingService_Tier["shipping-service (:8082, no HTTP port)"]
    SS[ShippingService]
    SCons[Shipping OrderConsumer]
    SProd[Shipping OrderProducer]
    SRepo[(ShipmentRepository / shipment collection)]
  end

  subgraph Kafka["Kafka topic: orders"]
    K((orders topic))
  end

  subgraph Mongo["MongoDB: reactive-systems db"]
    M[(shared database, separate collections)]
  end

  subgraph Infra["Infra / Deploy"]
    DC[docker-compose.yml]
    HC[Helm chart k8s/helm]
  end

  FE -->|POST /api/orders, GET SSE/JSON| OC
  FE -->|GET /api/products| PC
  OC --> OS
  OS --> ORepo
  OS -->|publish INITIATION_SUCCESS| OProd
  OProd --> K
  K --> OCons
  OCons -->|NEXT_STATUS map| OProd
  ORepo --- M

  VOC --> VOS
  VOS --> VORepo
  VOS -->|publish INITIATION_SUCCESS| VOProd
  VOProd --> K
  K --> VOCons
  VOCons --> VOProd
  VORepo --- M
  VORepo -.->|same order collection as ORepo, mutually exclusive| ORepo

  K -->|RESERVE_INVENTORY / REVERT_INVENTORY| ICons
  ICons --> PS
  PS --> PRepo
  PS -->|INVENTORY_SUCCESS / INVENTORY_FAILURE| IProd
  IProd --> K
  PRepo --- M
  PC --> PS

  K -->|PREPARE_SHIPPING| SCons
  SCons --> SS
  SS --> SRepo
  SS -->|SHIPPING_SUCCESS / SHIPPING_FAILURE| SProd
  SProd --> K
  SRepo --- M

  DC --> OrderService_Tier
  DC --> OrderServiceVT_Tier
  DC --> InventoryService_Tier
  DC --> ShippingService_Tier
  DC --> Frontend_Tier
  HC --> OrderService_Tier
  HC --> OrderServiceVT_Tier
  HC --> InventoryService_Tier
  HC --> ShippingService_Tier
  HC --> Frontend_Tier
