graph LR
  subgraph Programs
    OR[order-service.OrderRepository]
    OProd[order-service.OrderProducer]
    OCons[order-service.OrderConsumer]
    VOR[order-service-vt.OrderRepository]
    VOProd[order-service-vt.OrderProducer]
    VOCons[order-service-vt.OrderConsumer]
    PR[inventory-service.ProductRepository]
    IProd[inventory-service.OrderProducer]
    ICons[inventory-service.OrderConsumer]
    SR[shipping-service.ShipmentRepository]
    SProd[shipping-service.OrderProducer]
    SCons[shipping-service.OrderConsumer]
  end

  subgraph Stores
    K((orders topic))
    MO[(order collection)]
    MP[(product collection)]
    MS[(shipment collection)]
  end

  OR -- read/write --> MO
  VOR -- read/write --> MO
  OProd -- write --> K
  VOProd -- write --> K
  IProd -- write --> K
  SProd -- write --> K
  K -- dispatch/read --> OCons
  K -- dispatch/read --> VOCons
  K -- dispatch/read --> ICons
  K -- dispatch/read --> SCons
  PR -- read/write --> MP
  SR -- read/write --> MS

  classDef shared fill:#ffe6cc,stroke:#d79b00,stroke-width:2px;
  class MO,K shared
